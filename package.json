{
  "name": "mixlyai",
  "version": "2.0.0",
  "description": "AI playlist builder for YouTube Music and SoundCloud",
  "type": "module",
  "bin": {
    "mixlyai": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "chat": "node src/index.js chat",
    "auth": "node src/index.js auth",
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "setup:production": "node scripts/setup-production.mjs",
    "check:accounts": "node scripts/check-accounts.mjs",
    "check:integration": "node scripts/check-accounts.mjs --production",
    "vercel:env": "node scripts/add-vercel-env.mjs",
    "migrate:vercel": "node scripts/migrate-vercel-to-mixlyai.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "commander": "^13.1.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "supabase": "^2.105.0",
    "vercel": "^54.9.1"
  }
}
