{
  "name": "mixly",
  "version": "1.0.0",
  "description": "AI playlist curator with Claude — chat, save, and export track lists",
  "type": "module",
  "bin": {
    "mixly": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "chat": "node src/index.js chat",
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "setup:production": "node scripts/setup-production.mjs",
    "db:auth": "node scripts/apply-auth-schema.mjs",
    "check:accounts": "node scripts/check-accounts.mjs",
    "check:integration": "node scripts/check-accounts.mjs --production",
    "vercel:env": "node scripts/add-vercel-env.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "commander": "^13.1.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "supabase": "^2.105.0"
  }
}
