SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
# Local CLI auth (127.0.0.1). For Vercel, set to https://YOUR_APP.vercel.app/api/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Random 32+ char string — encrypts user session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=your_random_session_secret

# Site gate — leave empty to disable access code lock
SITE_ACCESS_CODE=your_access_code

# Chat mode (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (https://supabase.com/dashboard/project/npkmlflciakpzkskkqvy)
NEXT_PUBLIC_SUPABASE_URL=https://npkmlflciakpzkskkqvy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_EaBzw2QLLLKj-IgvwDX9WA_JEN-PggR
# Server-only — Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
