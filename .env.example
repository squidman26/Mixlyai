# YouTube Music (Google Cloud OAuth + YouTube Data API v3)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# SoundCloud (SoundCloud Developer Portal)
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret

# Production site URL (used for OAuth redirects from preview deployments)
APP_BASE_URL=https://mixlyai.vercel.app
# OAuth callback — must match provider redirect URIs exactly
OAUTH_REDIRECT_URI=https://mixlyai.vercel.app/api/auth/callback
# Local CLI auth only (src/music-cli.js)
# OAUTH_REDIRECT_URI=http://127.0.0.1:8888/callback

# Random 32+ char string — encrypts user session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=your_random_session_secret

# Site gate — leave empty to disable access code lock
SITE_ACCESS_CODE=your_access_code

# Chat mode (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Server-only — Settings → API → Secret key (sb_secret_...) or legacy service_role
SUPABASE_SECRET_KEY=your_supabase_secret_key
# Legacy alias still supported:
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Square payments (https://developer.squareup.com/)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
# sandbox or production (defaults to sandbox)
SQUARE_ENVIRONMENT=sandbox
# Webhook signature key from Square Developer Dashboard
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
# Optional override — defaults to APP_BASE_URL/api/webhooks/square
# SQUARE_WEBHOOK_URL=https://mixlyai.vercel.app/api/webhooks/square
# Optional comma-separated provider:userId entries with unlimited credits
# UNLIMITED_CREDITS_USER_IDS=youtube:abc123,soundcloud:456
