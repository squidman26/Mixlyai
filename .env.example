# Production site URL
APP_BASE_URL=https://mixlyai.vercel.app

# Random 32+ char string — encrypts user session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=your_random_session_secret

# Chat mode (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (https://supabase.com/dashboard/project/npkmlflciakpzkskkqvy)
NEXT_PUBLIC_SUPABASE_URL=https://npkmlflciakpzkskkqvy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_EaBzw2QLLLKj-IgvwDX9WA_JEN-PggR
# Server-only — Settings → API → Secret key (sb_secret_...) or legacy service_role
SUPABASE_SECRET_KEY=your_supabase_secret_key
# Legacy alias still supported:
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Square payments (https://developer.squareup.com/)
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_APPLICATION_SECRET=your_square_application_secret
# Sandbox/production access token from Developer Dashboard → Credentials
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
# sandbox or production (defaults to sandbox)
SQUARE_ENVIRONMENT=sandbox
# Webhook signature key from Square Developer Dashboard
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
# Optional override — defaults to APP_BASE_URL/api/webhooks/square
# SQUARE_WEBHOOK_URL=https://mixlyai.vercel.app/api/webhooks/square
# Optional comma-separated account UUIDs with unlimited credits
# UNLIMITED_CREDITS_ACCOUNT_IDS=

# Google OAuth for YouTube (https://console.cloud.google.com/apis/credentials)
# Web client ID — also set as external_google_client_id in Supabase Auth settings
GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Server token refresh + Supabase Google provider (same value)
GOOGLE_CLIENT_SECRET=your_google_client_secret
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your_google_client_secret
